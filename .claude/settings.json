{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-branch-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-write-lint.sh"
          }
        ]
      }
    ]
  }
}
