{
  "$defs": {
    "BundleGlossaryRef": {
      "description": "Public glossary reference for the reader.",
      "properties": {
        "kind": {
          "const": "glossary_ref",
          "default": "glossary_ref",
          "title": "Kind",
          "type": "string"
        },
        "term_id": {
          "title": "Term Id",
          "type": "string"
        },
        "surface_form": {
          "title": "Surface Form",
          "type": "string"
        },
        "ru_surface_form": {
          "default": "",
          "title": "Ru Surface Form",
          "type": "string"
        }
      },
      "required": [
        "term_id",
        "surface_form"
      ],
      "title": "BundleGlossaryRef",
      "type": "object"
    },
    "BundleSymbolRef": {
      "description": "Public symbol reference for the reader.",
      "properties": {
        "kind": {
          "const": "symbol",
          "default": "symbol",
          "title": "Kind",
          "type": "string"
        },
        "symbol_id": {
          "title": "Symbol Id",
          "type": "string"
        },
        "alt_text": {
          "default": "",
          "title": "Alt Text",
          "type": "string"
        }
      },
      "required": [
        "symbol_id"
      ],
      "title": "BundleSymbolRef",
      "type": "object"
    },
    "BundleTextRun": {
      "description": "Public text run for the reader.",
      "properties": {
        "kind": {
          "const": "text",
          "default": "text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "ru_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ru Text"
        },
        "bold": {
          "default": false,
          "title": "Bold",
          "type": "boolean"
        },
        "italic": {
          "default": false,
          "title": "Italic",
          "type": "boolean"
        },
        "monospace": {
          "default": false,
          "title": "Monospace",
          "type": "boolean"
        }
      },
      "required": [
        "text"
      ],
      "title": "BundleTextRun",
      "type": "object"
    }
  },
  "description": "Public heading block.",
  "properties": {
    "kind": {
      "const": "heading",
      "default": "heading",
      "title": "Kind",
      "type": "string"
    },
    "block_id": {
      "title": "Block Id",
      "type": "string"
    },
    "level": {
      "default": 1,
      "title": "Level",
      "type": "integer"
    },
    "content": {
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/BundleTextRun"
          },
          {
            "$ref": "#/$defs/BundleSymbolRef"
          },
          {
            "$ref": "#/$defs/BundleGlossaryRef"
          }
        ]
      },
      "title": "Content",
      "type": "array"
    },
    "anchor": {
      "default": "",
      "title": "Anchor",
      "type": "string"
    }
  },
  "required": [
    "block_id"
  ],
  "title": "BundleHeadingBlock",
  "type": "object"
}
