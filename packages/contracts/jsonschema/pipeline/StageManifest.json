{
  "$defs": {
    "StageErrorRecord": {
      "description": "Single error recorded during stage execution.",
      "properties": {
        "error_type": {
          "title": "Error Type",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        }
      },
      "required": [
        "error_type",
        "message"
      ],
      "title": "StageErrorRecord",
      "type": "object"
    },
    "WorkUnitStatus": {
      "description": "Status of a single work unit (page, translation unit, etc.).",
      "properties": {
        "unit_id": {
          "title": "Unit Id",
          "type": "string"
        },
        "status": {
          "default": "pending",
          "enum": [
            "pending",
            "running",
            "completed",
            "failed",
            "skipped"
          ],
          "title": "Status",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "cache_hit": {
          "default": false,
          "title": "Cache Hit",
          "type": "boolean"
        }
      },
      "required": [
        "unit_id"
      ],
      "title": "WorkUnitStatus",
      "type": "object"
    }
  },
  "description": "Stage-level status and work unit tracking.",
  "properties": {
    "stage_name": {
      "title": "Stage Name",
      "type": "string"
    },
    "stage_version": {
      "title": "Stage Version",
      "type": "string"
    },
    "status": {
      "default": "pending",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "Status",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "work_units": {
      "items": {
        "$ref": "#/$defs/WorkUnitStatus"
      },
      "title": "Work Units",
      "type": "array"
    },
    "input_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Input Hashes",
      "type": "object"
    },
    "output_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Output Hashes",
      "type": "object"
    },
    "metrics": {
      "additionalProperties": true,
      "title": "Metrics",
      "type": "object"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/StageErrorRecord"
      },
      "title": "Errors",
      "type": "array"
    }
  },
  "required": [
    "stage_name",
    "stage_version"
  ],
  "title": "StageManifest",
  "type": "object"
}
