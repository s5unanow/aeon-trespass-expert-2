{
  "$defs": {
    "NormalizedBBox": {
      "description": "Bounding box in normalized page-space coordinates [0, 1].\n\nOrigin is top-left: (0, 0) = top-left corner, (1, 1) = bottom-right.",
      "properties": {
        "x0": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "X0",
          "type": "number"
        },
        "y0": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Y0",
          "type": "number"
        },
        "x1": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "X1",
          "type": "number"
        },
        "y1": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Y1",
          "type": "number"
        }
      },
      "required": [
        "x0",
        "y0",
        "x1",
        "y1"
      ],
      "title": "NormalizedBBox",
      "type": "object"
    },
    "PageReadingOrder": {
      "description": "Linearised reading order for a single page.\n\nProduced from the PageRegionGraph by traversing bands top-to-bottom,\ncolumns left-to-right within each band, and emitting figures, tables,\nand callouts at their band position. Sidebars and callouts are tagged\nwith ``flow_role=\"aside\"``; full-width elements that interrupt a\nmulti-column flow are tagged ``flow_role=\"interruption\"``.\n\nArtifact path: ``{run}/evidence/p{page_number:04d}_reading_order.json``",
      "properties": {
        "page_number": {
          "title": "Page Number",
          "type": "integer"
        },
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "entries": {
          "items": {
            "$ref": "#/$defs/ReadingOrderEntry"
          },
          "title": "Entries",
          "type": "array"
        },
        "total_regions": {
          "default": 0,
          "title": "Total Regions",
          "type": "integer"
        },
        "unassigned_region_ids": {
          "items": {
            "type": "string"
          },
          "title": "Unassigned Region Ids",
          "type": "array"
        },
        "detection_version": {
          "default": "0.1.0",
          "title": "Detection Version",
          "type": "string"
        }
      },
      "required": [
        "page_number",
        "doc_id"
      ],
      "title": "PageReadingOrder",
      "type": "object"
    },
    "PageRegionGraph": {
      "description": "Region segmentation graph for a single page.\n\nProduced by collect_evidence after furniture subtraction. Contains\nspatial partitions with containment/adjacency relationships that\ndownstream stages (reading order, entity resolution) consume.\n\nArtifact path: ``{run}/evidence/p{page_number:04d}_regions.json``",
      "properties": {
        "page_number": {
          "title": "Page Number",
          "type": "integer"
        },
        "doc_id": {
          "title": "Doc Id",
          "type": "string"
        },
        "width_pt": {
          "title": "Width Pt",
          "type": "number"
        },
        "height_pt": {
          "title": "Height Pt",
          "type": "number"
        },
        "regions": {
          "items": {
            "$ref": "#/$defs/RegionCandidate"
          },
          "title": "Regions",
          "type": "array"
        },
        "edges": {
          "items": {
            "$ref": "#/$defs/RegionEdge"
          },
          "title": "Edges",
          "type": "array"
        },
        "furniture_ids_excluded": {
          "items": {
            "type": "string"
          },
          "title": "Furniture Ids Excluded",
          "type": "array"
        },
        "detection_version": {
          "default": "0.1.0",
          "title": "Detection Version",
          "type": "string"
        }
      },
      "required": [
        "page_number",
        "doc_id",
        "width_pt",
        "height_pt"
      ],
      "title": "PageRegionGraph",
      "type": "object"
    },
    "ReadingOrderEntry": {
      "description": "A single step in the linearised reading order.\n\nEach entry references a region from the PageRegionGraph and carries\nflow metadata so downstream stages know how to integrate the content.",
      "properties": {
        "sequence_index": {
          "minimum": 0,
          "title": "Sequence Index",
          "type": "integer"
        },
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "kind_hint": {
          "enum": [
            "main_flow",
            "column",
            "band",
            "sidebar",
            "callout",
            "figure",
            "table",
            "caption",
            "decoration",
            "furniture",
            "unknown"
          ],
          "title": "Kind Hint",
          "type": "string"
        },
        "flow_role": {
          "default": "main",
          "enum": [
            "main",
            "aside",
            "interruption"
          ],
          "title": "Flow Role",
          "type": "string"
        },
        "band_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Band Index"
        },
        "column_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column Index"
        },
        "confidence": {
          "$ref": "#/$defs/RegionConfidence"
        }
      },
      "required": [
        "sequence_index",
        "region_id",
        "kind_hint"
      ],
      "title": "ReadingOrderEntry",
      "type": "object"
    },
    "RegionCandidate": {
      "description": "A spatial partition of a page with a semantic kind hint.\n\nRegions are geometric hypotheses — ``kind_hint`` may be refined\nby later entity resolution stages.",
      "properties": {
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "kind_hint": {
          "enum": [
            "main_flow",
            "column",
            "band",
            "sidebar",
            "callout",
            "figure",
            "table",
            "caption",
            "decoration",
            "furniture",
            "unknown"
          ],
          "title": "Kind Hint",
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/NormalizedBBox"
        },
        "parent_region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Region Id"
        },
        "band_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Band Index"
        },
        "column_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column Index"
        },
        "source_evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Evidence Ids",
          "type": "array"
        },
        "features": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Features",
          "type": "object"
        },
        "confidence": {
          "$ref": "#/$defs/RegionConfidence"
        }
      },
      "required": [
        "region_id",
        "kind_hint",
        "bbox"
      ],
      "title": "RegionCandidate",
      "type": "object"
    },
    "RegionConfidence": {
      "description": "Confidence score with supporting reasons.",
      "properties": {
        "value": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Value",
          "type": "number"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        }
      },
      "title": "RegionConfidence",
      "type": "object"
    },
    "RegionEdge": {
      "description": "A typed relationship between two regions in a page region graph.",
      "properties": {
        "edge_type": {
          "enum": [
            "contains",
            "overlaps",
            "adjacent_to",
            "interrupts"
          ],
          "title": "Edge Type",
          "type": "string"
        },
        "src_region_id": {
          "title": "Src Region Id",
          "type": "string"
        },
        "dst_region_id": {
          "title": "Dst Region Id",
          "type": "string"
        }
      },
      "required": [
        "edge_type",
        "src_region_id",
        "dst_region_id"
      ],
      "title": "RegionEdge",
      "type": "object"
    }
  },
  "description": "Canonical page evidence after topology and entity analysis.\n\nProduced after region segmentation, reading-order reconstruction,\nand asset/entity resolution. Contains page-level graph outputs\nthat semantic block building consumes.\n\nRegion graph added by S5U-255 (Phase 2). Reading order added by\nS5U-256 (Phase 2). Asset registry added by S5U-257 (Phase 3).\nSymbol candidates will be added by S5U-258 through S5U-262.\n\nArtifact path: ``{run}/evidence/p{page_number:04d}_canonical.json``",
  "properties": {
    "page_number": {
      "title": "Page Number",
      "type": "integer"
    },
    "doc_id": {
      "title": "Doc Id",
      "type": "string"
    },
    "width_pt": {
      "title": "Width Pt",
      "type": "number"
    },
    "height_pt": {
      "title": "Height Pt",
      "type": "number"
    },
    "primitive_evidence_hash": {
      "default": "",
      "title": "Primitive Evidence Hash",
      "type": "string"
    },
    "estimated_column_count": {
      "default": 1,
      "title": "Estimated Column Count",
      "type": "integer"
    },
    "has_tables": {
      "default": false,
      "title": "Has Tables",
      "type": "boolean"
    },
    "has_figures": {
      "default": false,
      "title": "Has Figures",
      "type": "boolean"
    },
    "has_callouts": {
      "default": false,
      "title": "Has Callouts",
      "type": "boolean"
    },
    "furniture_fraction": {
      "default": 0.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Furniture Fraction",
      "type": "number"
    },
    "furniture_ids": {
      "items": {
        "type": "string"
      },
      "title": "Furniture Ids",
      "type": "array"
    },
    "template_id": {
      "default": "",
      "title": "Template Id",
      "type": "string"
    },
    "region_graph": {
      "anyOf": [
        {
          "$ref": "#/$defs/PageRegionGraph"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reading_order": {
      "anyOf": [
        {
          "$ref": "#/$defs/PageReadingOrder"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "asset_occurrence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Asset Occurrence Ids",
      "type": "array"
    }
  },
  "required": [
    "page_number",
    "doc_id",
    "width_pt",
    "height_pt"
  ],
  "title": "CanonicalPageEvidence",
  "type": "object"
}
