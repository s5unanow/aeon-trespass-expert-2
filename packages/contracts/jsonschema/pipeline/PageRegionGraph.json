{
  "$defs": {
    "NormalizedBBox": {
      "description": "Bounding box in normalized page-space coordinates [0, 1].\n\nOrigin is top-left: (0, 0) = top-left corner, (1, 1) = bottom-right.",
      "properties": {
        "x0": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "X0",
          "type": "number"
        },
        "y0": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Y0",
          "type": "number"
        },
        "x1": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "X1",
          "type": "number"
        },
        "y1": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Y1",
          "type": "number"
        }
      },
      "required": [
        "x0",
        "y0",
        "x1",
        "y1"
      ],
      "title": "NormalizedBBox",
      "type": "object"
    },
    "RegionCandidate": {
      "description": "A spatial partition of a page with a semantic kind hint.\n\nRegions are geometric hypotheses — ``kind_hint`` may be refined\nby later entity resolution stages.",
      "properties": {
        "region_id": {
          "title": "Region Id",
          "type": "string"
        },
        "kind_hint": {
          "enum": [
            "main_flow",
            "column",
            "band",
            "sidebar",
            "callout",
            "figure",
            "table",
            "caption",
            "decoration",
            "furniture",
            "unknown"
          ],
          "title": "Kind Hint",
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/NormalizedBBox"
        },
        "parent_region_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Region Id"
        },
        "band_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Band Index"
        },
        "column_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column Index"
        },
        "source_evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Evidence Ids",
          "type": "array"
        },
        "features": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Features",
          "type": "object"
        },
        "confidence": {
          "$ref": "#/$defs/RegionConfidence"
        }
      },
      "required": [
        "region_id",
        "kind_hint",
        "bbox"
      ],
      "title": "RegionCandidate",
      "type": "object"
    },
    "RegionConfidence": {
      "description": "Confidence score with supporting reasons.",
      "properties": {
        "value": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Value",
          "type": "number"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        }
      },
      "title": "RegionConfidence",
      "type": "object"
    },
    "RegionEdge": {
      "description": "A typed relationship between two regions in a page region graph.",
      "properties": {
        "edge_type": {
          "enum": [
            "contains",
            "overlaps",
            "adjacent_to",
            "interrupts"
          ],
          "title": "Edge Type",
          "type": "string"
        },
        "src_region_id": {
          "title": "Src Region Id",
          "type": "string"
        },
        "dst_region_id": {
          "title": "Dst Region Id",
          "type": "string"
        }
      },
      "required": [
        "edge_type",
        "src_region_id",
        "dst_region_id"
      ],
      "title": "RegionEdge",
      "type": "object"
    }
  },
  "description": "Region segmentation graph for a single page.\n\nProduced by collect_evidence after furniture subtraction. Contains\nspatial partitions with containment/adjacency relationships that\ndownstream stages (reading order, entity resolution) consume.\n\nArtifact path: ``{run}/evidence/p{page_number:04d}_regions.json``",
  "properties": {
    "page_number": {
      "title": "Page Number",
      "type": "integer"
    },
    "doc_id": {
      "title": "Doc Id",
      "type": "string"
    },
    "width_pt": {
      "title": "Width Pt",
      "type": "number"
    },
    "height_pt": {
      "title": "Height Pt",
      "type": "number"
    },
    "regions": {
      "items": {
        "$ref": "#/$defs/RegionCandidate"
      },
      "title": "Regions",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/RegionEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "furniture_ids_excluded": {
      "items": {
        "type": "string"
      },
      "title": "Furniture Ids Excluded",
      "type": "array"
    },
    "detection_version": {
      "default": "0.1.0",
      "title": "Detection Version",
      "type": "string"
    }
  },
  "required": [
    "page_number",
    "doc_id",
    "width_pt",
    "height_pt"
  ],
  "title": "PageRegionGraph",
  "type": "object"
}
