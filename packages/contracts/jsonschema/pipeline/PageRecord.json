  "description": "Canonical semantic representation of a single page.\n\nProduced by normalize_layout (03_normalize/pages/p0001.json).\nThis is the core IR — deterministic structure, no LLM output.",
  "properties": {
    "page_number": {
      "title": "Page Number",
      "type": "integer"
    },
    "doc_id": {
      "title": "Doc Id",
      "type": "string"
    },
    "width_pt": {
      "title": "Width Pt",
      "type": "number"
    },
    "height_pt": {
      "title": "Height Pt",
      "type": "number"
    },
    "render_mode": {
      "default": "semantic",
      "enum": [
        "semantic",
        "hybrid",
        "facsimile"
      ],
      "title": "Render Mode",
      "type": "string"
    },
    "fallback_image_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fallback Image Ref"
    },
    "blocks": {
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/HeadingBlock"
          },
          {
            "$ref": "#/$defs/ParagraphBlock"
          },
          {
            "$ref": "#/$defs/ListBlock"
          },
          {
            "$ref": "#/$defs/ListItemBlock"
          },
          {
            "$ref": "#/$defs/FigureBlock"
          },
          {
            "$ref": "#/$defs/CaptionBlock"
          },
          {
            "$ref": "#/$defs/TableBlock"
          },
          {
            "$ref": "#/$defs/CalloutBlock"
          },
          {
            "$ref": "#/$defs/DividerBlock"
          }
        ]
      },
      "title": "Blocks",
      "type": "array"
    },
    "anchors": {
      "items": {
        "$ref": "#/$defs/PageAnchor"
      },
      "title": "Anchors",
      "type": "array"
    },
    "source_pdf_sha256": {
      "default": "",
      "title": "Source Pdf Sha256",
      "type": "string"
    },
    "fingerprint": {
      "default": "",
      "title": "Fingerprint",
      "type": "string"
    }
  },
  "required": [
    "page_number",
    "doc_id",
    "width_pt",
    "height_pt"
  ],
  "title": "PageRecord",
  "type": "object"
}
