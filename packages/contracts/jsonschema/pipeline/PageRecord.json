    "CalloutBlock": {
      "description": "Highlighted callout / sidebar / tip box.",
      "properties": {
        "kind": {
          "const": "callout",
          "default": "callout",
          "title": "Kind",
          "type": "string"
        },
        "block_id": {
          "title": "Block Id",
          "type": "string"
        },
        "callout_type": {
          "default": "note",
          "title": "Callout Type",
          "type": "string"
        },
        "content": {
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/TextRun"
              },
              {
                "$ref": "#/$defs/SymbolRef"
              },
              {
                "$ref": "#/$defs/GlossaryRef"
              }
            ]
          },
          "title": "Content",
          "type": "array"
        },
        "source_block_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Block Index"
        }
      },
      "required": [
        "block_id"
      ],
      "title": "CalloutBlock",
      "type": "object"
    },
